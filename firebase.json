{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/models/Grops Bikes1.glb",
      "**/models/Bike_draco.glb",
      "**/models/Bike/**",
      "**/mapper.html"
    ],
    "headers": [
      {
        "source": "**/*.glb",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
          { "key": "Content-Type",  "value": "model/gltf-binary" }
        ]
      },
      {
        "source": "**/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
